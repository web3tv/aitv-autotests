{
  "name": "aitv-autotests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test:dev": "playwright test --config=playwright.config.ts",
    "test:critical": "playwright test --project=functional --grep @critical",
    "test:regression": "playwright test --project=functional",
    "test:nodb": "playwright test --project=functional --grep-invert @db",
    "test:visual": "docker run --rm -v \"$PWD:/app\" test npx playwright test --project=visual-desktop-chromium --project=visual-mobile-webkit",
    "test:visual:desktop": "docker run --rm -v \"$PWD:/app\" test npx playwright test --project=visual-desktop-chromium",
    "test:visual:mobile": "docker run --rm -v \"$PWD:/app\" test npx playwright test --project=visual-mobile-webkit",
    "delete-user": "npx ts-node scripts/deleteUser.ts",
    "seed:fixture": "npx ts-node scripts/seedFixture.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "imapflow": "^1.4.6",
    "mailparser": "^3.9.14",
    "mysql2": "^3.20.0",
    "tronweb": "^6.2.2"
  }
}
